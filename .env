DERIBIT_BASE_URL=https://www.deribit.com/api/v2
POLYMARKET_BASE_URL=https://clob.polymarket.com
BINANCE_BASE_URL=https://api.binance.com

# Use a near-term expiry - examples: 5MAR26, 6MAR26, 13MAR26
DERIBIT_EXPIRY=13MAR26

# Usually 500 on Deribit BTC options
STRIKE_INTERVAL=500
REQUEST_TIMEOUT_SECONDS=10
OUTPUT_DIR=data/raw

# Polymarket token ids - NOW AUTO-DISCOVERED!
# The collector automatically searches for "Bitcoin Up or Down - Hourly"
# markets matching "2-3AM ET" (07:00-08:00 UTC) each day.
# No manual token ID lookup needed - these fields can remain empty.
POLYMARKET_YES_TOKEN_ID=
POLYMARKET_NO_TOKEN_ID=
